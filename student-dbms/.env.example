# ─── MongoDB Atlas ───────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/studentDB?retryWrites=true&w=majority

# ─── Redis ───────────────────────────────────────────
# For local Redis:
REDIS_URL=redis://127.0.0.1:6379
# For Redis Cloud (example):
# REDIS_URL=redis://default:<password>@redis-xxxxx.c1.us-east-1-2.ec2.redns.redis-cloud.com:6379

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
